#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

start_service() {
	config_load openclash_sync
	local enabled
	config_get_bool enabled main enabled 1
	[ "$enabled" = "1" ] || return 0
	cleanup_leftovers
	procd_open_instance
	procd_set_param command /usr/bin/openclash_sync.sh watch
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

cleanup_leftovers() {
	# 只根据 /proc/<pid>/cmdline 精准杀本服务进程，避免误杀包含关键字的 ssh 管理会话
	for d in /proc/[0-9]*; do
		pid="${d#/proc/}"
		[ "$pid" = "$$" ] && continue
		[ -r "$d/cmdline" ] || continue
		cmd="$(cat "$d/cmdline" 2>/dev/null | tr '\0' ' ')"
		case "$cmd" in
			*"/usr/bin/openclash_sync.sh watch"*|*"inotifywait -m -r"*"/etc/openclash"*|"sleep 300"*)
				kill "$pid" 2>/dev/null || true
			;;
		esac
	done
	rm -rf /tmp/openclash_sync.lock /tmp/openclash_sync.pending /tmp/openclash_sync.debounce 2>/dev/null || true
}

stop_service() {
	cleanup_leftovers
}
