config openclash_sync 'main'
	option enabled '1'
	option debounce '5'
	option periodic_sync '300'
	option sync_config_file '1'
	option sync_config_dir '1'
	option sync_custom_dir '1'
	option sync_overwrite_dir '1'
	option sync_proxy_provider_dir '1'
	option sync_rule_provider_dir '1'
	option sync_game_rules_dir '1'
	option sync_root_assets '1'
	option log_file '/var/log/openclash_sync.log'

config node
	option enabled '1'
	option name '外网节点'
	option remote_host 'www.summer121.top'
	option remote_port '922'
	option remote_user 'root'
	option auth_mode 'key'
	option password ''
	option ssh_key '/root/.ssh/openclash_sync_openssh_ed25519'
	option known_hosts '/root/.ssh/openclash_sync_known_hosts'
	option reload_remote '1'
	option auto_deploy_openclash '0'
	option force_reinstall_mismatch '1'
	option backup_before_deploy '1'
